{
  "name": "db-mcp",
  "private": true,
  "description": "db-mcp — a multi-language, multi-database MCP server ecosystem",
  "workspaces": [
    "packages/*",
    "conformance"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
