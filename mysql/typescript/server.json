{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.arifulislamat/database-mcp-mysql",
  "description": "MCP server for MySQL databases. Read-only by default, row caps, statement timeouts, secrets never logged.",
  "repository": {
    "url": "https://github.com/arifulislamat/database-mcp",
    "source": "github"
  },
  "version": "0.4.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@database-mcp/mysql",
      "version": "0.4.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "MYSQL_HOST",
          "description": "Database host",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "MYSQL_USER",
          "description": "Database user (a read-only user is recommended)",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "MYSQL_PASSWORD",
          "description": "Database password (or use MYSQL_PASSWORD_FILE)",
          "isRequired": false,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "MYSQL_DATABASE",
          "description": "Database name",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ]
}
