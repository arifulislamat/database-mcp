{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.arifulislamat/database-mcp-postgres",
  "description": "MCP server for PostgreSQL. Read-only by default, row caps, timeouts, secrets never logged.",
  "repository": {
    "url": "https://github.com/arifulislamat/database-mcp",
    "source": "github"
  },
  "version": "0.4.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@database-mcp/postgres",
      "version": "0.4.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "POSTGRES_HOST",
          "description": "Database host",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "POSTGRES_USER",
          "description": "Database user (a read-only user is recommended)",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "POSTGRES_PASSWORD",
          "description": "Database password (or use POSTGRES_PASSWORD_FILE)",
          "isRequired": false,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "POSTGRES_DATABASE",
          "description": "Database name",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        }
      ]
    },
    {
      "registryType": "pypi",
      "identifier": "database-mcp-postgres",
      "version": "0.1.0",
      "runtimeHint": "uvx",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "POSTGRES_HOST",
          "description": "Database host",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "POSTGRES_USER",
          "description": "Database user (a read-only user is recommended)",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "POSTGRES_PASSWORD",
          "description": "Database password (or use POSTGRES_PASSWORD_FILE)",
          "isRequired": false,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "POSTGRES_DATABASE",
          "description": "Database name",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ]
}
